# ════════════════════════════════════════════════════════════════════════
#  pepvoga — environment template. Copy to `.env` and fill in real values.
# ════════════════════════════════════════════════════════════════════════

# ─── Database (Supabase Postgres in production) ──────────────────────────
# In the Supabase dashboard: Project Settings → Database → Connection string.
#   • DATABASE_URL → "Transaction" pooler (port 6543). Used at runtime.
#       append: ?pgbouncer=true&connection_limit=1
#   • DIRECT_URL   → "Session"/direct connection (port 5432). Used for migrations.
# Example:
# DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL=""
DIRECT_URL=""

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# ─── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo mode — bypasses login so the whole flow can be shown without auth.
# "true" (default) for the investor showcase; "false" to require real login.
NEXT_PUBLIC_DEMO_MODE="true"

# Admin WhatsApp number that booking quotes are sent to (wa.me).
NEXT_PUBLIC_ADMIN_WHATSAPP="+918586013386"

# ─── Supabase Storage (listing image uploads) ───────────────────────────
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Payments — PHASE 2 (not required for v1 bookable MVP) ───────────────
# India — Razorpay (incl. Route for owner payouts)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Global — Stripe (incl. Connect for owner payouts)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
